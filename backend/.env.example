# Admin dashboard login (required for API + UI access)
ADMIN_EMAIL=admin@sentinel.local
ADMIN_PASSWORD=change-this-strong-password
JWT_SECRET=generate-a-long-random-secret-at-least-32-chars
JWT_EXPIRE_HOURS=24

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# Comma-separated emails used when security_contacts table is empty
ALERT_EMAILS=you@example.com

# Gmail (must use App Password — NOT your normal Gmail password):
#   1. Enable 2-Step Verification on the Google account
#   2. https://myaccount.google.com/apppasswords → Mail → generate
#   3. SMTP_USER = that exact Gmail address; SMTP_PASSWORD = 16-char app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
SMTP_FROM=your@gmail.com
SMTP_USE_TLS=true
# If port 587 fails on your network, try: SMTP_PORT=465 SMTP_USE_SSL=true SMTP_USE_TLS=false

# Optional Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
